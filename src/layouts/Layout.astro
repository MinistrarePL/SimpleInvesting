---
import CookieBanner from '../components/CookieBanner.astro';
import PostHogInit from '../components/PostHogInit';
import PostHogFeedbackFab from '../components/PostHogFeedbackFab';

interface Props {
	title?: string;
}
const { title = 'Porównywarka ETF | SimpleInvesting' } = Astro.props;
/** Zawsze końcowy slash — `/favicon.svg`, nie `undefinedfavicon.svg` przy pustym BASE_URL */
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/?$/, '/');
---
<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<!-- Ikona zakładki: ICO + PNG — przeglądarki często żądają /favicon.ico zanim przeczytają <link> -->
		<link rel="icon" href={`${base}favicon.ico`} sizes="32x32" />
		<link rel="icon" type="image/png" sizes="228x228" href={`${base}favicon.png`} />
		<link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Skrypt zapobiegający FOUC (Flash of Unstyled Content) przy ładowaniu motywu -->
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();

			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>
	</head>
	<body>
		<PostHogInit client:only="react" />
		<PostHogFeedbackFab client:only="react" />
		<slot />

		<footer class="border-t border-theme-border bg-theme-surface text-theme-text-muted text-sm">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
				<p>&copy; {new Date().getFullYear()} SimpleInvesting</p>
				<nav class="flex flex-wrap items-center gap-x-4 gap-y-2">
					<a href="/privacy-policy" class="hover:text-theme-text transition-colors">
						<span data-footer-i18n="pl">Polityka prywatności</span>
						<span data-footer-i18n="en" class="hidden">Privacy Policy</span>
					</a>
					<a href="/terms-of-service" class="hover:text-theme-text transition-colors">
						<span data-footer-i18n="pl">Regulamin</span>
						<span data-footer-i18n="en" class="hidden">Terms of Service</span>
					</a>
					<button type="button" onclick="window.openCookieSettings && window.openCookieSettings()" class="hover:text-theme-text transition-colors">
						<span data-footer-i18n="pl">Ustawienia cookies</span>
						<span data-footer-i18n="en" class="hidden">Cookie settings</span>
					</button>
				</nav>
			</div>
		</footer>

		<script is:inline>
			(function () {
				var LANG_KEY = 'si.lang';
				function detectLang() {
					try {
						var stored = localStorage.getItem(LANG_KEY);
						if (stored === 'en' || stored === 'pl') return stored;
					} catch (e) {}
					var nav = (navigator.language || 'pl').toLowerCase();
					return nav.indexOf('pl') === 0 ? 'pl' : 'en';
				}
				function applyFooter(lang) {
					document.querySelectorAll('[data-footer-i18n]').forEach(function (el) {
						if (el.getAttribute('data-footer-i18n') === lang) {
							el.classList.remove('hidden');
						} else {
							el.classList.add('hidden');
						}
					});
				}
				applyFooter(detectLang());
				window.addEventListener('storage', function (e) {
					if (e.key === LANG_KEY) applyFooter(detectLang());
				});
				window.addEventListener('si:lang-change', function () {
					applyFooter(detectLang());
				});
			})();
		</script>

		<CookieBanner />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
