---
import Layout from '../layouts/Layout.astro';
import Dashboard from '../components/Dashboard';
import JsonLd from '../components/JsonLd.astro';
import '../styles/global.css';
import { createClient } from '@supabase/supabase-js';

const SITE = 'https://simpleinvesting.org';
const jsonLdGraph = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': `${SITE}/#organization`,
			name: 'SimpleInvesting',
			url: SITE,
			logo: `${SITE}/favicon.png`,
			email: 'contact@simpleinvesting.org',
			sameAs: [],
		},
		{
			'@type': 'WebSite',
			'@id': `${SITE}/#website`,
			url: SITE,
			name: 'SimpleInvesting',
			inLanguage: ['pl', 'en'],
			publisher: { '@id': `${SITE}/#organization` },
		},
		{
			'@type': 'WebApplication',
			'@id': `${SITE}/#webapp`,
			name: 'SimpleInvesting',
			url: SITE,
			applicationCategory: 'FinanceApplication',
			operatingSystem: 'Web',
			offers: {
				'@type': 'Offer',
				price: '0',
				priceCurrency: 'PLN',
			},
			featureList: [
				'Porównywarka ETF',
				'Wykresy 1Y/3Y/5Y',
				'Watchlist',
				'Filtry',
				'Eksport',
			],
			inLanguage: ['pl', 'en'],
			publisher: { '@id': `${SITE}/#organization` },
		},
	],
};

// Inicjalizacja Supabase po stronie serwera (SSR)
// Astro w trybie SSR na Netlify czasami potrzebuje process.env zamiast import.meta.env
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || process.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || process.env.PUBLIC_SUPABASE_ANON_KEY;

if (!supabaseUrl || !supabaseKey) {
  console.error('Brak kluczy Supabase w zmiennych środowiskowych!');
}

const supabase = createClient(supabaseUrl || '', supabaseKey || '');

/** PostgREST domyślnie zwraca max ~1000 wierszy — stronicujemy dla pełnej listy ETF. */
const PAGE = 1000;
let initialEtfs: Record<string, unknown>[] = [];
for (let from = 0; ; from += PAGE) {
    const { data: pageRows, error } = await supabase
      .from('etfs')
      .select('*')
      .not('category', 'is', null)
      .not('total_assets', 'is', null)
      .order('return_1y', { ascending: false, nullsFirst: false })
      .order('id', { ascending: true })
      .range(from, from + PAGE - 1);

  if (error) {
    console.error('Błąd pobierania danych z Supabase:', error);
    break;
  }
  if (!pageRows?.length) break;
  initialEtfs = initialEtfs.concat(pageRows);
  if (pageRows.length < PAGE) break;
}
---

<Layout
	title="SimpleInvesting — porównywarka ETF"
	description="Bezpłatna porównywarka ETF: filtry, wykresy 1Y/3Y/5Y, watchlist, opisy funduszy. Dane aktualizowane regularnie."
	canonicalPath="/"
>
	<JsonLd slot="seo-jsonld" data={jsonLdGraph} />
	<!-- Przekazujemy pobrane dane do interaktywnego komponentu React -->
	<Dashboard initialEtfs={initialEtfs} client:load />
</Layout>
