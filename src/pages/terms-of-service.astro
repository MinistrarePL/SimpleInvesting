<script is:inline>
	(function () {
		var stored = (typeof localStorage !== 'undefined' && localStorage.getItem('si.lang')) || 'pl';
		var current = stored === 'en' ? 'en' : 'pl';

		function apply(lang) {
			document.querySelectorAll('[data-lang-content]').forEach(function (el) {
				if (el.getAttribute('data-lang-content') === lang) {
					el.classList.remove('hidden');
				} else {
					el.classList.add('hidden');
				}
			});
			document.querySelectorAll('[data-i18n="back-home-pl"]').forEach(function (el) {
				el.classList.toggle('hidden', lang !== 'pl');
			});
			document.querySelectorAll('[data-i18n="back-home-en"]').forEach(function (el) {
				el.classList.toggle('hidden', lang !== 'en');
			});
			document.querySelectorAll('[data-lang-btn]').forEach(function (btn) {
				var isActive = btn.getAttribute('data-lang-btn') === lang;
				btn.classList.toggle('bg-theme-primary', isActive);
				btn.classList.toggle('text-white', isActive);
				btn.classList.toggle('bg-theme-surface', !isActive);
				btn.classList.toggle('text-theme-text', !isActive);
			});
			document.documentElement.setAttribute('lang', lang);
			try { localStorage.setItem('si.lang', lang); } catch (e) {}
			window.dispatchEvent(new CustomEvent('si:lang-change', { detail: lang }));
		}

		document.querySelectorAll('[data-lang-btn]').forEach(function (btn) {
			btn.addEventListener('click', function () {
				apply(btn.getAttribute('data-lang-btn'));
			});
		});

		apply(current);
	})();
</script>
