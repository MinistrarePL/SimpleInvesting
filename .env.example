# See README for EODHD / Supabase variables (EODHD_API_KEY, PUBLIC_SUPABASE_URL, etc.).

# PostHog — EU cloud (https://eu.posthog.com).
# Set in Netlify for production. Session recording is enabled in the PostHog project.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Survey UUID from PostHog → Surveys → your survey URL or settings (API / programmatic display).
# Set survey “Presentation” to API; use PostHogFeedbackFab for the visible button.

PUBLIC_POSTHOG_FEEDBACK_SURVEY_ID=

# Cloudflare Turnstile (invisible captcha for Supabase Auth).
# Create a site at https://dash.cloudflare.com -> Turnstile, then:
#   - paste the SITE KEY below (public, ends up in client bundle),
#   - paste the SECRET KEY in Supabase dashboard -> Authentication -> Bot and Abuse Protection.
# Local dev: Supabase still expects a token if bot protection is enabled. Copy the same SITE KEY
# into .env and under the Turnstile site add hostnames "localhost" and "127.0.0.1", then restart `npm run dev`.
PUBLIC_TURNSTILE_SITE_KEY=

# OpenAI API key for the ETF AI Assistant (GPT-5.1).
# Get yours at https://platform.openai.com/api-keys
# This key is server-side only — it must NOT have a PUBLIC_ prefix.
OPENAI_API_KEY=

# --- Knowledge base (PDF → Supabase, asystent AI) ---
# SQL Editor: uruchom supabase-migration-knowledge.sql (tabela + FTS RPC).
# extract:knowledge i npm run build (prebuild) synchronizują chunki przy ustawionych:
SUPABASE_SERVICE_ROLE_KEY=
